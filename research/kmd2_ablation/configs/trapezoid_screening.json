{
  "schema_version": "1.0.0", "suite_version": "1.0.0", "backend": "tiny",
  "qwen": {"model_asset": "qwen_model", "tokenizer_asset": "qwen_tokenizer", "run_mode": "initial_exact_cache", "streaming": false, "decode": false, "packing": false, "padding": "none", "attention_mask": "all_ones"},
  "baseline": "gdn2_native", "mechanism": "trapezoid", "variant": "trapezoid",
