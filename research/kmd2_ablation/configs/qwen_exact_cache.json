    "name": "adamw",
    "learning_rate": 0.0001,
    "betas": [0.9, 0.95],
    "eps": 1e-8,
    "weight_decay": 0.01
  },
  "schedule": {"name": "cosine", "warmup_updates": 4},
  "model": {
    "hidden_size": 2048,
    "num_layers": 18,
    "num_heads": 16,
    "state_key_dim": 128,
    "state_value_dim": 128,
    "ffn_dim": 6144,
    "ffn_match_lower": 6080,
    "ffn_match_upper": 6208
  },
  "lengths": {
    "curriculum": [512, 2048, 4096, 8192],
    "extrapolation": [16384, 32768]
  },
  "evaluation": {"primary_metric": "ruler_long_macro", "direction": "maximize"},
  "thresholds": {
    "min_useful_addition": 0.02,
    "min_reliance": 0.1,
    "equivalence_tolerance": 0.01,
    "harm_threshold": 0.03,
    "synergy_threshold": 0.02
  },
  "promotion": {
    "min_gate_mean": 0.005,
    "min_gate_max": 0.02,
    "min_persistent_hit_rate": 0.25,
    "min_conditional_read_accuracy": 0.5,
    "min_shuffled_cache_dependence": 0.05,
    "min_adjacent_capacity_lcb": 0.05
  },
  "protected_metrics": [
    {"name": "validation_loss", "max_regression": 0.01},
    {"name": "short_context_accuracy", "max_regression": 0.01},
    {"name": "freshness_stale_error", "max_regression": 0.01}
  ],
  "device_preferences": ["cuda"],
  "dtype_preferences": ["bfloat16"],
  "required_stage": "qwen_heal",
  "cache": {
    "width": 64,
    "block_size": 256,
    "score": "exact_outer",
    "read": "rmsnorm",
    "read_init": "gamma_one_sink_zero_amplitude_zero",
    "eps_cache": 1e-6,
    "coordinate_frame": "rotated_recurrence",
    "pre_rotation_diagnostic": false,
    "storage_dtype": "bf16",
    "compute_dtype": "fp32",
    "inclusive": true,
    "tie_policy": "score_desc_position_desc",
    "lr_cache": 0.0002,
    "weight_decay_cache": 0.0
  },
  "runtime": {"output_path": "outputs/qwen-exact-cache", "device_ordinal": 0}
