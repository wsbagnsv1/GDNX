{
  "schema_version": "1.0.0",
  "suite_version": "1.0.0",
  "backend": "tiny",
  "qwen": {
    "model_asset": "qwen_model",
    "tokenizer_asset": "qwen_tokenizer",
    "run_mode": "initial_exact_cache",
    "streaming": false,
    "decode": false,
    "packing": false,
    "padding": "none",
    "attention_mask": "all_ones"
  },
  "baseline": "gdn2_native",
  "mechanism": "exact_cache",
  "variant": "top_surprise",
  "task": {
    "name": "mqar",
    "params": {"width": 4}
  },
  "seeds": [11],
  "budget": {"tokens": 28, "updates": 2},
  "optimizer": {
    "name": "adamw",
    "learning_rate": 0.005,
    "betas": [0.9, 0.95],
    "eps": 1e-8,
    "weight_decay": 0.01
  },
  "schedule": {"name": "cosine", "warmup_updates": 1},
  "model": {
    "hidden_size": 8,
    "num_layers": 1,
    "num_heads": 1,
    "state_key_dim": 2,
    "state_value_dim": 2,
    "ffn_dim": 16,
    "ffn_match_lower": 8,
    "ffn_match_upper": 24
  },
  "lengths": {"curriculum": [4], "extrapolation": [8, 16]},
  "evaluation": {"primary_metric": "exact_match", "direction": "maximize"},
  "thresholds": {
    "min_useful_addition": 0.02,
    "min_reliance": 0.1,
    "equivalence_tolerance": 0.01,
    "harm_threshold": 0.03,
    "synergy_threshold": 0.02
  },
  "promotion": {
    "min_gate_mean": 0.005,
    "min_gate_max": 0.02,
    "min_persistent_hit_rate": 0.25,
    "min_conditional_read_accuracy": 0.5,
    "min_shuffled_cache_dependence": 0.05,
    "min_adjacent_capacity_lcb": 0.05
  },
  "protected_metrics": [
    {"name": "validation_loss", "max_regression": 0.01}
  ],
  "device_preferences": ["cpu"],
  "dtype_preferences": ["float32"],
  "required_stage": "selector_replay",
  "cache": {
    "width": 2,
    "block_size": 2,
    "score": "exact_outer",
    "read": "unit_l2",
    "read_init": "gamma_one_sink_zero_amplitude_zero",
    "eps_cache": 1e-6,
    "coordinate_frame": "rotated_recurrence",
    "pre_rotation_diagnostic": false,
    "storage_dtype": "fp32",
    "compute_dtype": "fp32",
    "inclusive": true,
    "tie_policy": "score_desc_position_desc",
    "lr_cache": 0.01,
    "weight_decay_cache": 0.0
  },
  "runtime": {"output_path": "outputs/smoke", "device_ordinal": 0}
}
